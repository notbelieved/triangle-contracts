[package]
name = "stylus-deal-vault"
version = "0.1.0"
edition = "2021"
description = "Minimal gas Stylus escrow vault: receive, transfer, freeze, owner control"

[lib]
crate-type = ["lib", "cdylib"]

[dependencies]
stylus-sdk = "0.10"

[features]
export-abi = ["stylus-sdk/export-abi"]

[profile.release]
codegen-units = 1
strip = true
lto = true
panic = "abort"
opt-level = "z"
